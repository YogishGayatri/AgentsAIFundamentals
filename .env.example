# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in the keys you actually have.
#   cp .env.example .env
#
# You only need ONE provider to do the whole course. Groq is the default
# because it is free and fast. Everything reads from this file via providers.py.
# ─────────────────────────────────────────────────────────────────────────────

# Which provider get_chat_model() uses when you don't pass one explicitly.
# One of: groq | gemini | fm
PROVIDER=groq

# --- Groq (default) ---------------------------------------------------------
# Free key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# --- Google Gemini (optional) ----------------------------------------------
# Free key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_key_here

# --- FM Gateway (optional, OpenAI-compatible) ------------------------------
# Internal 3DS Foundation Models gateway. Talks the OpenAI API, so we point
# the OpenAI client at its base_url. Swagger: https://fmgateway.proxem.dsone.3ds.com/docs
FM_API_KEY=your_fm_key_here
FM_BASE_URL=https://fmgateway.proxem.dsone.3ds.com/v1
